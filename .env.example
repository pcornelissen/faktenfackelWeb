# Bluesky (AT Protocol)
# App-Passwort erstellen: https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=faktenfackel.bsky.social
BLUESKY_APP_PASSWORD=

# Mastodon
# Token erstellen: https://mastodon.social/settings/applications
# Rechte: write:statuses, write:media
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# X/Twitter (Free Tier, nur Text)
# Developer Portal: https://developer.x.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Facebook (Page)
# Graph API Explorer: https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# Instagram (Business Account via Facebook)
# Gleicher Token wie Facebook, Instagram User ID separat
INSTAGRAM_USER_ID=

# TikTok
# Developer Portal: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
