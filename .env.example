# nuxt-og-image: Signatur-Secret fuer dynamisch generierte OG-Bilder (Anti-Abuse).
# Wird zur BUILD-Zeit gelesen und in die Nitro-runtimeConfig eingefroren
# (nicht zur Laufzeit). Lokal gehoert dieser Wert in eine .env-Datei
# (NICHT .env.local) — nuxi laedt nur .env automatisch. In Produktion als
# Docker-Build-Arg aus dem GitHub-Secret NUXT_OG_IMAGE_SECRET injiziert
# (siehe .github/workflows/deploy-hetzner.yml).
# Neues Secret erzeugen: npx nuxt-og-image generate-secret
NUXT_OG_IMAGE_SECRET=

# Bluesky (AT Protocol)
# App-Passwort erstellen: https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=faktenfackel.bsky.social
BLUESKY_APP_PASSWORD=

# Mastodon
# Token erstellen: https://mastodon.social/settings/applications
# Rechte: write:statuses, write:media
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# X/Twitter: wird ausschliesslich manuell via Browser gepostet (keine API).

# Facebook (Page)
# Graph API Explorer: https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# Instagram (Business Account via Facebook)
# Gleicher Token wie Facebook, Instagram User ID separat
INSTAGRAM_USER_ID=

# TikTok
# Developer Portal: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
