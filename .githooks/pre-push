#!/bin/sh
cd "$(git rev-parse --show-toplevel)" || exit 1

# Lokale pre-push-Checks laufen NUR beim Push auf main.
#
# Auf dev/Feature-Branches wird uebersprungen: dort ist schnelles committen +
# pushen erwuenscht. Feedback liefert die CI, die ohnehin auf jedem Branch-Push
# laeuft; der verbindliche Gate ist die CI im PR nach main (main ist PR-only mit
# required status check). Direkter main-Push (selten/blockiert) fuehrt die
# Checks weiterhin als Sicherheitsnetz aus. Siehe FF-20.
#
# pre-push erhaelt die zu pushenden Refs auf stdin:
#   <local ref> <local sha> <remote ref> <remote sha>
pushing_main=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
	[ "$remote_ref" = "refs/heads/main" ] && pushing_main=1
done

if [ "$pushing_main" -eq 0 ]; then
	echo "pre-push: kein main-Push -> lokale Checks uebersprungen (CI + PR-nach-main-Gate greifen)."
	exit 0
fi

echo "Running lint..."
pnpm lint || { echo "Lint failed — push aborted."; exit 1; }

echo "Running typecheck..."
pnpm typecheck || { echo "Typecheck failed — push aborted."; exit 1; }

echo "Verifying no client-side content queries..."
pnpm verify:no-client-queries || { echo "Client-seitige Content-Queries gefunden (FF-19) — push aborted."; exit 1; }

echo "Running content lint (changed files only)..."
pnpm check:content --changed --quiet || { echo "Content-Lint fehlgeschlagen. Voll-Check: 'pnpm check:content'. Auto-Fix: 'pnpm check:content:fix' — push aborted."; exit 1; }

echo "Building and checking HTML..."
pnpm build --quiet 2>/dev/null && pnpm check:build || { echo "Build or HTML check failed — push aborted."; exit 1; }

echo "All checks passed."
