#!/bin/sh
cd "$(git rev-parse --show-toplevel)" || exit 1

echo "Running lint..."
pnpm lint || { echo "Lint failed — push aborted."; exit 1; }

echo "Running typecheck..."
pnpm typecheck || { echo "Typecheck failed — push aborted."; exit 1; }

echo "Running content lint..."
pnpm check:content --quiet || { echo "Content-Lint fehlgeschlagen. Details: 'pnpm check:content'. Auto-Fix: 'pnpm check:content:fix' — push aborted."; exit 1; }

echo "All checks passed."
